              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "List strategies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/strategies",
              "host": ["{{baseUrl}}"],
              "path": ["strategies"]
            }
          }
        },
        {
          "name": "Strategy: sol-native-stake",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/strategies/sol-native-stake",
              "host": ["{{baseUrl}}"],
              "path": ["strategies", "sol-native-stake"]
            }
          }
        },
        {
          "name": "Strategy: sol-liquid-stake",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/strategies/sol-liquid-stake",
              "host": ["{{baseUrl}}"],
              "path": ["strategies", "sol-liquid-stake"]
            }
          }
        },
        {
          "name": "Strategy: sol-leveraged-stake (LIVE)",
          "request": {
            "method": "GET",
            "description": "Leveraged raSOL Max. Now live for programmatic deposit (SOL input) + unstake (raSOL Max LP input). `actions.stake.kinds = [deposit]`, `actions.unstake.kinds = [instant]`.",
            "url": {
              "raw": "{{baseUrl}}/strategies/sol-leveraged-stake",
              "host": ["{{baseUrl}}"],
              "path": ["strategies", "sol-leveraged-stake"]
            }
          }
        },
        {
          "name": "Strategy: usdc-earn",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/strategies/usdc-earn",
              "host": ["{{baseUrl}}"],
              "path": ["strategies", "usdc-earn"]
            }
          }
        },
        {
          "name": "APY history: sol-native-stake (1M)",
          "request": {
