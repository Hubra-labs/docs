          "name": "APY history: sol-liquid-stake (3M)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/apy/history?strategy=sol-liquid-stake&range=3M",
              "host": ["{{baseUrl}}"],
              "path": ["apy", "history"],
              "query": [
                { "key": "strategy", "value": "sol-liquid-stake" },
                { "key": "range", "value": "3M" }
              ]
            }
          }
        },
        {
          "name": "APY history: sol-leveraged-stake (6M)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/apy/history?strategy=sol-leveraged-stake&range=6M",
              "host": ["{{baseUrl}}"],
