        {
          "name": "List tokens",
          "request": {
            "method": "GET",
            "description": "Token metadata catalogue (mints, symbols, decimals, logos) for every asset the strategies touch. Each token is also addressable at /tokens/:slug.",
            "url": {
              "raw": "{{baseUrl}}/tokens",
              "host": ["{{baseUrl}}"],
              "path": ["tokens"]
            }
          }
        },
        {
          "name": "Token: rasol",
          "request": {
            "method": "GET",
            "description": "Single token by slug. Try other slugs from the /tokens list (e.g. sol, usdc, rasol-max, rausdc).",
            "url": {
              "raw": "{{baseUrl}}/tokens/rasol",
              "host": ["{{baseUrl}}"],
              "path": ["tokens", "rasol"]
            }
          }
        },
        {
          "name": "Push: VAPID public key",
          "request": {
            "method": "GET",
            "description": "Returns the server's VAPID public key for Web Push subscription.",
            "url": {
              "raw": "{{baseUrl}}/push/key",
              "host": ["{{baseUrl}}"],
              "path": ["push", "key"]
            }
          }
        }
      ]
    },
    {
      "name": "Quote",
      "item": [
        {
          "name": "Quote: sol-liquid-stake (raSOL → SOL)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-liquid-stake\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"1.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/quote",
              "host": ["{{baseUrl}}"],
              "path": ["quote"]
            }
          }
        },
        {
          "name": "Quote: sol-native-stake instant (active stake → SOL)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\":     \"sol-native-stake\",\n  \"wallet\":       \"{{wallet}}\",\n  \"stakeAccount\": \"{{stakeAccount}}\",\n  \"amount\":       \"1.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/quote",
              "host": ["{{baseUrl}}"],
              "path": ["quote"]
            }
          }
        },
        {
          "name": "Quote: sol-leveraged-stake (raSOL Max LP → raSOL)",
          "request": {
            "method": "POST",
            "description": "Previews a leveraged withdraw. `amount` = raSOL Max LP to burn. Returns expected raSOL payout (`outAmount`) and the redemption `path` (vault-idle | flash-bracket). Non-binding - NAV drifts between quote and unstake. There's no deposit-side quote: the SOL → raSOL mint is a deterministic floor-division from the pool snapshot. usdc-earn has no quote either - its withdraw is a direct vault redemption with no slippage.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-leveraged-stake\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"{{lpAmount}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/quote",
              "host": ["{{baseUrl}}"],
              "path": ["quote"]
            }
          }
        }
      ]
    },
    {
      "name": "Stake",
      "item": [
        {
          "name": "Stake: sol-native-stake (delegate to Hubra validator)",
          "request": {
            "method": "POST",
            "description": "Server generates the fresh stake-account keypair and pre-signs its slot. Agent only signs the wallet slot. The new stake-account pubkey is returned under `stakeAccount` - save it for future deactivate / withdraw / instant unstake. Broadcast over RPC.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-native-stake\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"1.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/stake",
              "host": ["{{baseUrl}}"],
              "path": ["stake"]
            }
          }
        },
        {
          "name": "Stake: sol-liquid-stake (mint raSOL via Sanctum)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-liquid-stake\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"1.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/stake",
              "host": ["{{baseUrl}}"],
              "path": ["stake"]
            }
          }
        },
        {
          "name": "Stake: sol-leveraged-stake (SOL → raSOL Max, LIVE)",
          "request": {
            "method": "POST",
            "description": "Deposit SOL into Leveraged raSOL Max. `amount` is SOL. Builds ONE tx: create raSOL ATA (idempotent) → SPL stake-pool DepositSol (SOL → raSOL) → Voltr depositVault (raSOL → raSOL Max LP). Returns route=rpc + hubra_token. Sign as the wallet, broadcast via the RPC broadcast request. After it confirms, read your raSOL Max LP balance on-chain and set the `lpAmount` collection variable for the leveraged unstake.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-leveraged-stake\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"0.02\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/stake",
              "host": ["{{baseUrl}}"],
              "path": ["stake"]
            }
          }
        },
        {
          "name": "Stake: usdc-earn (deposit into Voltr vault)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"usdc-earn\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"5.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/stake",
              "host": ["{{baseUrl}}"],
              "path": ["stake"]
            }
          }
        }
      ]
    },
    {
      "name": "Unstake",
      "item": [
        {
          "name": "Unstake: sol-native-stake deactivate (epoch-bounded ~2.5d)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\":     \"sol-native-stake\",\n  \"wallet\":       \"{{wallet}}\",\n  \"stakeAccount\": \"{{stakeAccount}}\",\n  \"kind\":         \"deactivate\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/unstake",
              "host": ["{{baseUrl}}"],
              "path": ["unstake"]
            }
          }
        },
        {
          "name": "Unstake: sol-native-stake instant (Sanctum depositStake)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\":     \"sol-native-stake\",\n  \"wallet\":       \"{{wallet}}\",\n  \"stakeAccount\": \"{{stakeAccount}}\",\n  \"amount\":       \"1.0\",\n  \"kind\":         \"instant\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/unstake",
              "host": ["{{baseUrl}}"],
              "path": ["unstake"]
            }
          }
        },
        {
          "name": "Unstake: sol-liquid-stake instant (raSOL → SOL routed)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-liquid-stake\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"1.0\",\n  \"kind\":     \"instant\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/unstake",
              "host": ["{{baseUrl}}"],
              "path": ["unstake"]
            }
          }
        },
        {
          "name": "Unstake: sol-liquid-stake slow (raSOL → stake account → epoch deactivate)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-liquid-stake\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"1.0\",\n  \"kind\":     \"slow\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/unstake",
              "host": ["{{baseUrl}}"],
              "path": ["unstake"]
            }
          }
        },
        {
          "name": "Unstake: sol-leveraged-stake instant (burn raSOL Max LP → raSOL)",
          "request": {
            "method": "POST",
            "description": "Burns raSOL Max LP and pays out raSOL. `amount` = raSOL Max LP to burn (decimal, 9 decimals) - set the `lpAmount` variable to your on-chain LP balance after a leveraged deposit. Routes via the SDK's vault-idle (1 ix) or MarginFi flash-bracket (8-10 ixs + ALT) path; the response `path` field tells you which. First-ever redemption lazily inits the user's MarginFi account (~0.005 SOL one-shot rent). Returns route=rpc - broadcast over RPC. To finish to SOL, follow with a sol-liquid-stake instant unstake on the resulting raSOL.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-leveraged-stake\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"{{lpAmount}}\",\n  \"kind\":     \"instant\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/unstake",
              "host": ["{{baseUrl}}"],
              "path": ["unstake"]
            }
          }
        },
        {
          "name": "Unstake: sol-leveraged-stake instant → SOL (chained)",
          "request": {
            "method": "POST",
            "description": "Same single LP → raSOL withdraw tx, but `outputAsset: \"SOL\"` attaches a ready-to-run `next` step that converts the resulting raSOL → SOL via a sol-liquid-stake instant unstake. The SOL leg can't be built in the same call (Sanctum won't quote until the burned raSOL lands), so: broadcast THIS tx, read the raSOL your wallet actually received, then fire the `next` call with that exact amount. The `next.body.amount` returned here is the build-time estimate.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\":    \"sol-leveraged-stake\",\n  \"wallet\":      \"{{wallet}}\",\n  \"amount\":      \"{{lpAmount}}\",\n  \"kind\":        \"instant\",\n  \"outputAsset\": \"SOL\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/unstake",
              "host": ["{{baseUrl}}"],
              "path": ["unstake"]
            }
          }
        },
        {
          "name": "Unstake: usdc-earn instant (partial)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"usdc-earn\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"5.0\",\n  \"kind\":     \"instant\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/unstake",
              "host": ["{{baseUrl}}"],
              "path": ["unstake"]
            }
          }
        },
        {
          "name": "Unstake: usdc-earn instant (withdraw all)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\":      \"usdc-earn\",\n  \"wallet\":        \"{{wallet}}\",\n  \"kind\":          \"instant\",\n  \"isWithdrawAll\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/unstake",
              "host": ["{{baseUrl}}"],
              "path": ["unstake"]
            }
          }
        },
        {
          "name": "Withdraw: native stake (after deactivation epoch)",
          "request": {
            "method": "POST",
            "description": "Closes a native stake account once it's reached `inactive` state (deactivation epoch passed, ~2.5d after /unstake kind=deactivate). Pulls all lamports back to the wallet by default, or pass `lamports` (number) for a partial withdraw. Uses the stakeAccount pubkey returned by the original /stake call (auto-captured into lastStakeAccount).",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"wallet\":       \"{{wallet}}\",\n  \"stakeAccount\": \"{{lastStakeAccount}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/withdraw",
              "host": ["{{baseUrl}}"],
              "path": ["withdraw"]
            }
          }
        }
      ]
    },
    {
      "name": "Broadcast",
      "item": [
        {
          "name": "Broadcast via Solana RPC (default)",
          "request": {
            "method": "POST",
            "description": "Plain Solana RPC. Use for native, sol-leveraged-stake, and usdc-earn flows (route=rpc). Replace signed_tx with the base64 of your locally-signed transaction. hubra_token is auto-pulled from the most recent /stake or /unstake response - if you haven't run one yet, paste the value manually.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signed_tx\":   \"REPLACE_WITH_BASE64_SIGNED_TX\",\n  \"hubra_token\": \"{{lastHubraToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/broadcast",
              "host": ["{{baseUrl}}"],
              "path": ["broadcast"]
            }
          }
        },
        {
          "name": "Broadcast via Sanctum (MEV-protected, swap flows)",
          "request": {
            "method": "POST",
            "description": "Use for txs returned with route=sanctum from /stake or /unstake (sol-liquid-stake, sol-native-stake instant). Adds MEV protection + smarter retries. All four Sanctum-specific fields are auto-injected from collection variables: hubra_token, sanctumKind (token | depositStake | depositSol | withdrawStake), and sanctum_order (the original Sanctum order response that Sanctum's execute endpoint validates against). Replace signed_tx with your locally-signed bytes.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signed_tx\":     \"REPLACE_WITH_BASE64_SIGNED_TX\",\n  \"hubra_token\":   \"{{lastHubraToken}}\",\n  \"route\":         \"sanctum\",\n  \"sanctumKind\":   \"{{lastSanctumKind}}\",\n  \"sanctum_order\": {{lastSanctumOrder}}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/broadcast",
              "host": ["{{baseUrl}}"],
              "path": ["broadcast"]
            }
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Track wallet",
          "request": {
            "method": "POST",
            "description": "Register a wallet for balance-snapshot + points tracking. `walletName` is the optional Wallet Standard adapter name (e.g. \"Phantom\").",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"wallet\":     \"{{wallet}}\",\n  \"walletName\": \"Phantom\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/wallet/track",
              "host": ["{{baseUrl}}"],
              "path": ["wallet", "track"]
            }
          }
        }
      ]
    },
    {
      "name": "Push",
      "item": [
        {
          "name": "Subscribe (Web Push, SIWS-gated)",
          "request": {
            "method": "POST",
            "description": "Register a Web Push subscription. Requires a SIWS proof (sign-in-with-Solana message + base58 ed25519 signature) binding the subscription to `userId` (the wallet). Replace the subscription + proof placeholders with real values from the browser PushManager + wallet adapter.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{wallet}}\",\n  \"subscription\": {\n    \"endpoint\": \"https://fcm.googleapis.com/fcm/send/REPLACE\",\n    \"keys\": {\n      \"p256dh\": \"REPLACE_P256DH\",\n      \"auth\":   \"REPLACE_AUTH\"\n    }\n  },\n  \"proof\": {\n    \"message\":   \"REPLACE_WITH_SIWS_MESSAGE\",\n    \"signature\": \"REPLACE_WITH_BASE58_SIGNATURE\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/push/subscribe",
              "host": ["{{baseUrl}}"],
              "path": ["push", "subscribe"]
            }
          }
        },
        {
          "name": "Unsubscribe",
          "request": {
            "method": "POST",
            "description": "Remove a Web Push subscription by its endpoint.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endpoint\": \"https://fcm.googleapis.com/fcm/send/REPLACE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/push/unsubscribe",
              "host": ["{{baseUrl}}"],
              "path": ["push", "unsubscribe"]
            }
          }
        }
      ]
    },
    {
      "name": "Errors",
      "item": [
        {
          "name": "404: unknown strategy",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/strategies/bogus",
              "host": ["{{baseUrl}}"],
              "path": ["strategies", "bogus"]
            }
          }
        },
        {
          "name": "400: missing required fields",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-liquid-stake\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/stake",
              "host": ["{{baseUrl}}"],
              "path": ["stake"]
            }
          }
        },
        {
          "name": "400: invalid kind for strategy",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-liquid-stake\",\n  \"wallet\":   \"{{wallet}}\",\n  \"amount\":   \"1.0\",\n  \"kind\":     \"deactivate\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/unstake",
              "host": ["{{baseUrl}}"],
              "path": ["unstake"]
            }
          }
        },
        {
          "name": "400: leveraged unstake missing amount",
          "request": {
            "method": "POST",
            "description": "sol-leveraged-stake unstake requires `amount` (raSOL Max LP to burn). Omitting it returns 400.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"sol-leveraged-stake\",\n  \"wallet\":   \"{{wallet}}\",\n  \"kind\":     \"instant\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/unstake",
              "host": ["{{baseUrl}}"],
              "path": ["unstake"]
            }
          }
        },
        {
          "name": "400: invalid range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/apy/history?strategy=usdc-earn&range=BAD",
              "host": ["{{baseUrl}}"],
              "path": ["apy", "history"],
              "query": [
                { "key": "strategy", "value": "usdc-earn" },
                { "key": "range", "value": "BAD" }
              ]
            }
          }
        },
        {
          "name": "403: invalid hubra_token on /broadcast",
          "request": {
            "method": "POST",
            "description": "/broadcast rejects any signed_tx + hubra_token combo where the token doesn't match the tx's message hash, is malformed, or expired. Get a fresh token from /stake or /unstake.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signed_tx\":   \"AQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA\",\n  \"hubra_token\": \"99999.deadbeef\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/broadcast",
              "host": ["{{baseUrl}}"],
              "path": ["broadcast"]
            }
          }
        }
      ]
    }
  ]
}
